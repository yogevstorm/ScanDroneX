<launch>

  <!-- slam -->
  <include file="$(find-pkg-share slam)/launch/slam.launch.py"/>

  <!-- laser odometry (feeds EKF; TF broadcast disabled) -->
  <include file="$(find-pkg-share rf2o_laser_odometry)/launch/rf2o_laser_odometry.launch.py"/>

  <!-- EKF: fuses odom_rf2o + odom_cmd_vel into ekf_odom (required by SLAM) -->
  <include file="$(find-pkg-share ekf_localization)/launch/ekf.launch.py"/>

</launch>

